{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["teacher", "student"] },
        "name": { "type": "string" },
        "subject": { "type": "string", "description": "Subject (if teacher)" },
        "classCode": { "type": "string", "description": "Class code (if student)" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["role", "name", "createdAt", "updatedAt"]
    },
    "Class": {
      "title": "Class",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "code", "teacherId", "createdAt", "updatedAt"]
    },
    "Student": {
      "title": "Student",
      "description": "Represents a student in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Academic ID provided by user" },
        "userId": { "type": "string", "description": "The user who created and owns this student record." },
        "name": { "type": "string" },
        "className": { "type": "string" },
        "score": { "type": "number" },
        "performance": { "type": "string", "enum": ["ممتاز", "جيد", "ضعيف"] },
        "status": { "type": "string", "enum": ["normal", "alert"] },
        "attendance": { "type": "number", "description": "Number of days present" },
        "participation": { "type": "number", "description": "Participation points" },
        "deductions": { "type": "number", "description": "Deducted points" },
        "behavioralNotes": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "userId", "name", "className", "score", "performance", "status", "attendance", "participation", "deductions", "behavioralNotes", "createdAt", "updatedAt"]
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["task", "test"] },
        "deadline": { "type": "string" },
        "completed": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "type", "deadline", "completed", "userId", "createdAt", "updatedAt"]
    },
    "ScheduleItem": {
      "title": "ScheduleItem",
      "type": "object",
      "properties": {
        "time": { "type": "string" },
        "subject": { "type": "string" },
        "grade": { "type": "string" },
        "room": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["time", "subject", "grade", "room", "userId", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "author": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["content", "author", "userId", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" }
    },
    "classes/{classId}": {
      "schema": { "$ref": "#/entities/Class" }
    },
    "students/{studentId}": {
      "schema": { "$ref": "#/entities/Student" }
    },
    "tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" }
    },
    "schedule/{itemId}": {
      "schema": { "$ref": "#/entities/ScheduleItem" }
    },
    "messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" }
    }
  }
}
